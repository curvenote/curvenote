enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Job {
  id                String             @id
  date_created      String
  date_modified     String
  job_type          String
  status            JobStatus
  payload           Json
  results           Json?
  messages          String[]
  follow_on         Json?
  SubmissionVersion SubmissionVersion?
  linkedJobs        LinkedJob[]
}

model LinkedJob {
  id              String      @id
  date_created    String
  job             Job         @relation(fields: [job_id], references: [id], onDelete: Cascade)
  job_id          String
  work_version    WorkVersion @relation(fields: [work_version_id], references: [id], onDelete: Cascade)
  work_version_id String

  @@index([work_version_id])
}
