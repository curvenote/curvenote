{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "api/**", "public/build/**"]
    },
    "@curvenote/scms-db#build": {
      "inputs": [
        "../../prisma/**",
        "./src"
      ],
      "outputs": ["dist/**"]
    },
    "clean": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "lint:format": {
      "outputs": []
    },
    "lint:format:fix": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "dev": {
      "cache": false
    }
  }
}
