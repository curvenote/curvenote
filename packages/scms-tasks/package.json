{
  "name": "@curvenote/scms-tasks",
  "version": "0.14.3",
  "description": "SCMS tasks library: job client and helpers for cloud runners",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/curvenote/curvenote.git"
  },
  "scripts": {
    "gcp-build": "npm run build",
    "clean": "rimraf dist",
    "build:esm": "tsc --outDir dist",
    "build": "npm-run-all -l clean -p build:esm",
    "dev:esm": "tsc --outDir dist --watch",
    "dev": "npm-run-all -l -p dev:esm",
    "lint": "eslint \"src/**/*.ts\" -c ./.eslintrc.cjs",
    "lint:format": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@curvenote/common": "^0.3.4"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "devDependencies": {
    "@types/express": "^4.17.13",
    "@types/node": "^22.9.0",
    "dotenv": "^16.0.1",
    "eslint": "^8.21.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.1.3",
    "vitest": "^1.2.2"
  }
}
